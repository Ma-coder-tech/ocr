# Required to enable Anthropic refinement stage
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Model to use with AI SDK Anthropic provider.
# If unset, defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Cost controls
AI_MAX_INPUT_TOKENS=4000
AI_MAX_OUTPUT_TOKENS=600

# Optional: AI-assisted fee classification for unresolved processor fee rows.
# Deterministic parsing/classification always runs first; this only sends
# structured unresolved fee rows to AI providers when enabled.
AI_FEE_CLASSIFICATION_ENABLED=false
# auto tries Anthropic first when configured, then OpenAI as fallback.
AI_FEE_CLASSIFICATION_PROVIDER=auto
AI_FEE_CLASSIFICATION_MODEL=claude-opus-4-8
AI_FEE_CLASSIFICATION_OPENAI_MODEL=gpt-5.5
AI_FEE_CLASSIFICATION_ESCALATION_MODEL=claude-fable-5
AI_FEE_CLASSIFICATION_ESCALATION_MIN_AMOUNT=100
AI_FEE_CLASSIFICATION_APPLY_MIN_CONFIDENCE=medium
AI_FEE_CLASSIFICATION_MAX_INPUT_TOKENS=12000
AI_FEE_CLASSIFICATION_MAX_OUTPUT_TOKENS=2000
AI_FEE_CLASSIFICATION_TIMEOUT_MS=8000

# Server settings
PORT=3000
HOST=127.0.0.1
APP_ORIGIN=https://yourapp.com
