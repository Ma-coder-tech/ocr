{
  "name": "ocr-fee-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.3",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "build:web": "vite build --config web/vite.config.ts",
    "build:all": "npm run build && npm run build:web",
    "typecheck:web": "tsc -p web/tsconfig.json",
    "start": "NODE_ENV=production node dist/server.js",
    "test": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs ./node_modules/vitest/vitest.mjs run",
    "parser:audit": "tsx scripts/parser-audit.ts",
    "fiserv:coverage": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs --import tsx scripts/fiserv-coverage-audit.ts",
    "bakeoff:pdf": "npm run build && node scripts/pdf-bakeoff.mjs",
    "bakeoff:azure": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs --import tsx scripts/azure-layout-bakeoff.ts",
    "bakeoff:document-ir": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs --import tsx scripts/document-ir-bakeoff.ts",
    "bakeoff:fiserv-document-ir": "node scripts/check-toolchain.mjs && node scripts/run-node-tool.mjs --import tsx scripts/document-ir-bakeoff.ts",
    "validate:foundation": "node scripts/validate-merchant-foundation.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.70",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.9.0",
    "csv-parse": "^5.5.6",
    "dotenv": "^17.3.1",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "4.19.3",
    "typescript": "5.8.2",
    "vite": "^5.4.21",
    "vitest": "2.1.9"
  }
}
